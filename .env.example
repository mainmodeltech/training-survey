# ─────────────────────────────────────────────────────────
# CORAF Formation — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter .env dans git !
# ─────────────────────────────────────────────────────────

# Domaine public
DOMAIN=coraf.model-technologie.com

# PostgreSQL
POSTGRES_DB=coraf_db
POSTGRES_USER=coraf_user
POSTGRES_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_DB_FORT

# JWT — générer avec : openssl rand -hex 32
SECRET_KEY=CHANGEZ_MOI_CLE_JWT_256_BITS_MINIMUM

# Durée du token admin (en minutes)
TOKEN_EXPIRE_MINUTES=480
